{
  "name": "memoria-kit",
  "version": "0.1.0",
  "description": "Contextual Memory and Prompt Optimization Toolkit for LLM-powered development",
  "type": "module",
  "bin": {
    "memoria": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "assets",
    "README.md",
    "PLAN.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests"
  },
  "keywords": [
    "llm",
    "memory",
    "prompt-engineering",
    "tokens",
    "skills",
    "claude",
    "openai",
    "ai",
    "context",
    "embeddings",
    "semantic-search",
    "copilot",
    "cursor"
  ],
  "author": "GergesBernaba1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GergesBernaba1/Memoria.git",
    "directory": "memoria"
  },
  "bugs": {
    "url": "https://github.com/GergesBernaba1/Memoria/issues"
  },
  "homepage": "https://github.com/GergesBernaba1/Memoria#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@xenova/transformers": "^2.17.2",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "gray-matter": "^4.0.3",
    "js-tiktoken": "^1.0.14",
    "openai": "^4.67.0",
    "picomatch": "^4.0.2",
    "typescript": "^5.6.2",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.16.10",
    "@types/picomatch": "^3.0.1",
    "eslint": "^10.2.1",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript-eslint": "^8.59.1",
    "vitest": "^2.1.2"
  }
}
